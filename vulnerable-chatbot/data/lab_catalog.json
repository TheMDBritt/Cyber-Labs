{
  "labs": [
    {
      "id": "LAB-001",
      "belt": "White",
      "title": "Helpdesk Prompt Injection Sandbox",
      "learning_objectives": [
        "Identify abuse path in mock system",
        "Implement preventive controls",
        "Add detection alerts",
        "Validate with safe tests"
      ],
      "scenario": "Mock-only environment with synthetic data and non-production endpoints.",
      "attack_simulation_steps": [
        "Load provided sandbox inputs",
        "Run constrained abuse prompts",
        "Record observed failures"
      ],
      "defense_build_steps": [
        "Apply policy and boundary controls",
        "Harden retrieval/tool rules",
        "Add safe fallback behavior"
      ],
      "detection_monitoring_steps": [
        "Add structured logs",
        "Create threshold alerts",
        "Review anomaly dashboard"
      ],
      "success_criteria": [
        "Attack success rate drops",
        "Alerts trigger correctly",
        "No sensitive leak in outputs"
      ],
      "common_mistakes": [
        "Relying on one control",
        "No telemetry validation",
        "Skipping retest"
      ],
      "reflection_questions": [
        "Which control failed first?",
        "What signal detected earliest?",
        "What would you automate next?"
      ]
    },
